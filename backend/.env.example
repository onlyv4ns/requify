DATABASE_URL=postgres://requify:requify@localhost:5432/requify?sslmode=disable
AUTH_SECRET=
FRONTEND_ORIGIN=http://localhost:3000

# Provider "api" — requires an Anthropic API key
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Provider "claude_code" — uses the `claude` CLI already logged in on this
# server, no API key needed. Leave empty to use the CLI's default model.
CLAUDE_CODE_MODEL=
